Rule: main_epoch_spec_m_canon_deqP
Predicate: (PrimArrayDynSelect (PrimBuildArray (main_epoch_spec_m_valid_lat_0.whas
						? ! main_epoch_spec_m_valid_lat_0.wget[0]
						: (! main_epoch_spec_m_valid_rl[0]))
					       (main_epoch_spec_m_valid_lat_0.whas
						? ! main_epoch_spec_m_valid_lat_0.wget[1]
						: (! main_epoch_spec_m_valid_rl[1])))
